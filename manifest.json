{
  "manifest_version": 3,
  "name": "Link-Shield",
  "version": "1.0",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8787/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "web_accessible_resources": [{
    "resources": ["warning.html", "scan.html"],
    "matches": ["<all_urls>"]
  }]
}
